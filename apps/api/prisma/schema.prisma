// Creado y diseñado por XO
// schema.prisma — XLayout Master SaaS Backend
// Version: commercial-multitenant-v2 | Build: 2026-03-23
// Architecture: Multi-tenant, single schema, tenant_id column strategy
// Incluye modelo comercial: Fabricante → Distribuidor → Diseñador → Usuario Final

generator client {
  provider      = "prisma-client-js"
  engineType    = "binary"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum PlatformRole {
  PLATFORM_OWNER
  PLATFORM_ADMIN
}

enum CompanyUserRole {
  TENANT_ADMIN
  BUSINESS_OWNER
  CATALOG_MANAGER
  SALES_USER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum TenantStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING
}

enum ProductStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ImportJobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum AuditActorType {
  PLATFORM_USER
  COMPANY_USER
  DISTRIBUTOR_USER
  END_USER
  SYSTEM
}

// Rol del usuario dentro de la empresa distribuidora
enum DistributorUserRole {
  DISTRIBUTOR_ADMIN  // Administrador de la empresa distribuidora
  DESIGNER           // Diseñador — usa el editor y genera propuestas
  SALES              // Vendedor — genera cotizaciones comerciales
}

// Alcance del incremento comercial del distribuidor
enum MarkupScope {
  GLOBAL       // Aplica a todos los productos de todos los fabricantes
  BY_TENANT    // Aplica a todos los productos de un fabricante específico
  BY_LINE      // Aplica a una línea de producto
  BY_PRODUCT   // Aplica a un producto específico
}

// ============================================================
// LAYER 1 — PLATFORM USERS (Xocotzin and platform admins)
// ============================================================

model PlatformUser {
  id           String       @id @default(uuid())
  email        String       @unique
  passwordHash String       @map("password_hash")
  firstName    String       @map("first_name")
  lastName     String       @map("last_name")
  role         PlatformRole @default(PLATFORM_ADMIN)
  status       UserStatus   @default(ACTIVE)
  preferences  Json?
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  auditLogs    AuditLog[]   @relation("PlatformUserAuditor")
  tenantsCreated Tenant[]   @relation("TenantCreator")

  @@map("platform_users")
}

// ============================================================
// LAYER 2 — TENANT / COMPANY / BRAND
// ============================================================

model Tenant {
  id           String       @id @default(uuid())
  name         String
  slug         String       @unique
  status       TenantStatus @default(PENDING)
  logoUrl      String?      @map("logo_url")
  contactEmail String?      @map("contact_email")
  createdById  String?      @map("created_by_id")
  metadata     Json?
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  createdBy        PlatformUser?    @relation("TenantCreator", fields: [createdById], references: [id])
  companyUsers     CompanyUser[]
  productLines     ProductLine[]
  productCategories ProductCategory[]
  products         Product[]
  productAssets    ProductAsset[]
  productPrices    ProductPrice[]
  productConditions ProductCondition[]
  productVariants  ProductVariant[]
  catalogAccesses  CatalogAccess[]
  activationCodes  ActivationCode[]
  importJobs       ImportJob[]
  auditLogs        AuditLog[]       @relation("TenantAudit")

  // Relaciones del modelo comercial de distribuidores
  distributorAccesses        ManufacturerDistributorAccess[]
  distributorCatalogAccesses DistributorCatalogAccess[]

  // Legacy backward-compat relations (existing schema)
  legacyBrands     Brand[]              @relation("LegacyBrands")
  legacyPriceLists CompanyPriceList[]   @relation("LegacyCompanyPriceLists")
  legacyDiscountRules DiscountRule[]    @relation("LegacyDiscountRules")
  projects         Project[]

  @@map("tenants")
}

// ============================================================
// LAYER 3a — COMPANY USERS (internal, per-tenant)
// ============================================================

model CompanyUser {
  id           String          @id @default(uuid())
  tenantId     String          @map("tenant_id")
  email        String          @unique
  passwordHash String          @map("password_hash")
  firstName    String          @map("first_name")
  lastName     String          @map("last_name")
  role         CompanyUserRole @default(CATALOG_MANAGER)
  status       UserStatus      @default(ACTIVE)
  preferences  Json?
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")

  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  catalogAccesses CatalogAccess[] @relation("CatalogActivator")
  importJobs      ImportJob[]     @relation("ImportCreator")
  auditLogs       AuditLog[]      @relation("CompanyUserAuditor")

  @@map("company_users")
}

// ============================================================
// LAYER 3b — END USERS (free users: architects, designers, distributors)
// ============================================================

model EndUser {
  id           String     @id @default(uuid())
  email        String     @unique
  passwordHash String     @map("password_hash")
  firstName    String     @map("first_name")
  lastName     String     @map("last_name")
  phone        String?
  companyName  String?    @map("company_name")
  profession   String?    // 'architect' | 'designer' | 'distributor' | 'other'
  country      String?
  status       UserStatus @default(ACTIVE)
  preferences  Json?
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  catalogAccesses CatalogAccess[]
  auditLogs       AuditLog[]       @relation("EndUserAuditor")

  @@map("end_users")
}

// ============================================================
// CATALOG LAYER
// ============================================================

model ProductLine {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  name        String
  slug        String
  category    String?
  description String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant   Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products Product[]
  productConditions ProductCondition[]

  @@unique([tenantId, slug])
  @@map("product_lines")
}

model ProductCategory {
  id       String  @id @default(uuid())
  tenantId String  @map("tenant_id")
  name     String
  slug     String
  parentId String? @map("parent_id")
  active   Boolean @default(true)

  tenant   Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent   ProductCategory?  @relation("CategoryTree", fields: [parentId], references: [id])
  children ProductCategory[] @relation("CategoryTree")
  products Product[]

  @@unique([tenantId, slug])
  @@map("product_categories")
}

model Product {
  id          String        @id @default(uuid())
  tenantId    String        @map("tenant_id")
  lineId      String        @map("line_id")
  categoryId  String?       @map("category_id")
  sku         String
  name        String
  description String?
  width       Float
  depth       Float
  height      Float
  active      Boolean       @default(true)
  status      ProductStatus @default(DRAFT)
  metadata    Json?

  tenant     Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  line       ProductLine      @relation(fields: [lineId], references: [id])
  category   ProductCategory? @relation(fields: [categoryId], references: [id])
  assets     ProductAsset[]
  prices     ProductPrice[]
  conditions ProductCondition[]
  variants   ProductVariant[]

  @@unique([tenantId, sku])
  @@map("products")
}

model ProductAsset {
  id                String   @id @default(uuid())
  tenantId          String   @map("tenant_id")
  productId         String   @map("product_id")
  assetType         String   // 'image' | 'model_3d' | 'footprint_svg' | 'thumbnail'
  fileUrl           String?  @map("file_url")
  thumbnailUrl      String?  @map("thumbnail_url")
  footprint2dUrl    String?  @map("footprint_2d_url")
  model3dUrl        String?  @map("model_3d_url")
  // ── Conversion Pipeline ─────────────────────────────────────────────────
  originalFileUrl   String?  @map("original_file_url")   // path to uploaded source file
  originalFormat    String?  @map("original_format")      // 'glb' | 'obj' | 'dae' | 'fbx' | ...
  conversionStatus  String   @default("pending") @map("conversion_status")  // pending|processing|converted|validated|failed|url_only
  conversionError   String?  @map("conversion_error")
  metadata          Json?    // technical: triangles, materials, bbox, fileSize, validationStatus
  createdAt         DateTime @default(now()) @map("created_at")

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_assets")
}

model ProductPrice {
  id          String    @id @default(uuid())
  tenantId    String    @map("tenant_id")
  productId   String    @map("product_id")
  priceType   String    @default("A") @map("price_type") // 'A'|'B'|'C'|'D'|'E'
  currency    String    @default("MXN")
  basePrice   Decimal   @map("base_price") @db.Decimal(12, 2)
  active      Boolean   @default(true)
  validFrom   DateTime? @map("valid_from")
  validTo     DateTime? @map("valid_to")
  metadata    Json?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, priceType])
  @@map("product_prices")
}

model ProductCondition {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  productId     String?  @map("product_id")  // null = applies to whole line
  lineId        String?  @map("line_id")
  conditionType String   @map("condition_type") // 'warranty' | 'delivery' | 'commercial' | 'custom'
  description   String
  metadata      Json?
  active        Boolean  @default(true)
  createdAt     DateTime @default(now()) @map("created_at")

  tenant  Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product Product?     @relation(fields: [productId], references: [id])
  line    ProductLine? @relation(fields: [lineId], references: [id])

  @@map("product_conditions")
}

// ============================================================
// ACCESS CONTROL
// ============================================================

/// Links a Tenant (company) to an EndUser, controlling what they can see
model CatalogAccess {
  id                  String    @id @default(uuid())
  tenantId            String    @map("tenant_id")
  endUserId           String    @map("end_user_id")
  catalogEnabled      Boolean   @default(true)  @map("catalog_enabled")
  pricesEnabled       Boolean   @default(false) @map("prices_enabled")
  conditionsEnabled   Boolean   @default(false) @map("conditions_enabled")
  activatedByUserId   String?   @map("activated_by_user_id")
  activationCodeId    String?   @map("activation_code_id")
  active              Boolean   @default(true)
  activatedAt         DateTime  @default(now()) @map("activated_at")
  expiresAt           DateTime? @map("expires_at")

  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  endUser         EndUser         @relation(fields: [endUserId], references: [id], onDelete: Cascade)
  activatedBy     CompanyUser?    @relation("CatalogActivator", fields: [activatedByUserId], references: [id])
  activationCode  ActivationCode? @relation(fields: [activationCodeId], references: [id])

  @@unique([tenantId, endUserId])
  @@map("catalog_accesses")
}

model ActivationCode {
  id                String    @id @default(uuid())
  tenantId          String    @map("tenant_id")
  code              String    @unique
  catalogEnabled    Boolean   @default(true)  @map("catalog_enabled")
  pricesEnabled     Boolean   @default(false) @map("prices_enabled")
  conditionsEnabled Boolean   @default(false) @map("conditions_enabled")
  maxUses           Int?      @map("max_uses")
  usedCount         Int       @default(0) @map("used_count")
  expiresAt         DateTime? @map("expires_at")
  active            Boolean   @default(true)
  createdAt         DateTime  @default(now()) @map("created_at")

  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  catalogAccesses CatalogAccess[]

  @@map("activation_codes")
}

// ============================================================
// AUDIT & IMPORT
// ============================================================

model AuditLog {
  id          String         @id @default(uuid())
  actorType   AuditActorType @map("actor_type")
  actorId     String         @map("actor_id")
  tenantId    String?        @map("tenant_id")
  action      String         // 'CREATE_TENANT' | 'ENABLE_CATALOG' | 'ACTIVATE_CODE' etc.
  entityType  String         @map("entity_type")
  entityId    String?        @map("entity_id")
  payload     Json?
  createdAt   DateTime       @default(now()) @map("created_at")

  tenant      Tenant?      @relation("TenantAudit", fields: [tenantId], references: [id])
  platformUser PlatformUser? @relation("PlatformUserAuditor", fields: [actorId], references: [id], map: "audit_platform_user_fk")
  companyUser  CompanyUser?  @relation("CompanyUserAuditor", fields: [actorId], references: [id], map: "audit_company_user_fk")
  endUser      EndUser?      @relation("EndUserAuditor", fields: [actorId], references: [id], map: "audit_end_user_fk")

  @@map("audit_logs")
}

model ImportJob {
  id          String          @id @default(uuid())
  tenantId    String          @map("tenant_id")
  type        String          // 'PRODUCTS' | 'PRICES' | 'CONDITIONS'
  filename    String
  status      ImportJobStatus @default(PENDING)
  summary     Json?           // { total, succeeded, failed, errors: [...] }
  createdById String          @map("created_by_id")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  tenant    Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy CompanyUser @relation("ImportCreator", fields: [createdById], references: [id])

  @@map("import_jobs")
}

// ============================================================
// MODELO COMERCIAL — DISTRIBUIDORES (commercial-multitenant-v2)
// ============================================================

// Empresa distribuidora — actor comercial intermedio entre fabricante y diseñador
model DistributorCompany {
  id           String     @id @default(uuid())
  name         String
  slug         String     @unique
  contactEmail String?    @map("contact_email")
  phone        String?
  country      String?
  status       UserStatus @default(ACTIVE)
  metadata     Json?
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  // Usuarios internos del distribuidor (diseñadores, administradores, vendedores)
  users                  DistributorUser[]
  // Catálogos de fabricantes autorizados
  manufacturerAccesses   ManufacturerDistributorAccess[]
  // Acceso específico a listas de precio de cada fabricante
  catalogAccesses        DistributorCatalogAccess[]
  // Reglas de incremento comercial
  priceMarkups           DistributorPriceMarkup[]

  @@map("distributor_companies")
}

// Usuario dentro de una empresa distribuidora — diseñadores, comerciales, admin
model DistributorUser {
  id             String              @id @default(uuid())
  distributorId  String              @map("distributor_id")
  email          String              @unique
  passwordHash   String              @map("password_hash")
  firstName      String              @map("first_name")
  lastName       String              @map("last_name")
  role           DistributorUserRole @default(DESIGNER)
  status         UserStatus          @default(ACTIVE)
  preferences    Json?
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")

  // Relación con su empresa distribuidora
  distributor    DistributorCompany @relation(fields: [distributorId], references: [id], onDelete: Cascade)

  @@map("distributor_users")
}

// Autorización de un fabricante hacia un distribuidor — tabla de control de acceso macro
model ManufacturerDistributorAccess {
  id             String    @id @default(uuid())
  tenantId       String    @map("tenant_id")       // Fabricante (Tenant)
  distributorId  String    @map("distributor_id")  // Distribuidor autorizado
  active         Boolean   @default(true)
  grantedAt      DateTime  @default(now()) @map("granted_at")
  expiresAt      DateTime? @map("expires_at")
  notes          String?   // Notas internas del fabricante sobre esta autorización

  tenant       Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  distributor  DistributorCompany @relation(fields: [distributorId], references: [id], onDelete: Cascade)

  // Un distribuidor solo puede tener UN acceso activo por fabricante
  @@unique([tenantId, distributorId])
  @@map("manufacturer_distributor_accesses")
}

// Qué lista de precios recibe el distribuidor para un fabricante específico
model DistributorCatalogAccess {
  id             String   @id @default(uuid())
  distributorId  String   @map("distributor_id")
  tenantId       String   @map("tenant_id")        // Fabricante
  // Tipo de lista de precios asignada: 'A'|'B'|'C'|'D'|'E'
  priceListType  String   @default("A") @map("price_list_type")
  active         Boolean  @default(true)
  grantedAt      DateTime @default(now()) @map("granted_at")

  distributor  DistributorCompany @relation(fields: [distributorId], references: [id], onDelete: Cascade)
  tenant       Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Un distribuidor solo puede tener UN acceso de catálogo por fabricante
  @@unique([distributorId, tenantId])
  @@map("distributor_catalog_accesses")
}

// Regla de incremento comercial del distribuidor — flexible por scope
// Precio final = precioBase * (1 + markupPercent / 100)
model DistributorPriceMarkup {
  id             String      @id @default(uuid())
  distributorId  String      @map("distributor_id")
  scope          MarkupScope @default(GLOBAL)
  // Contexto del scope — null si no aplica para el nivel seleccionado
  tenantId       String?     @map("tenant_id")        // Si scope = BY_TENANT
  productLineId  String?     @map("product_line_id")  // Si scope = BY_LINE
  productId      String?     @map("product_id")       // Si scope = BY_PRODUCT
  // Porcentaje de incremento: 15.0000 = 15%
  markupPercent  Decimal     @map("markup_percent") @db.Decimal(8, 4)
  active         Boolean     @default(true)
  // Mayor prioridad = se aplica primero si hay múltiples reglas que apliquen
  priority       Int         @default(0)
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  distributor  DistributorCompany @relation(fields: [distributorId], references: [id], onDelete: Cascade)

  @@map("distributor_price_markups")
}

// Variante de producto — preparada para expansión futura (colores, texturas, materiales)
// No tiene UI ni endpoints activos en esta fase; es la estructura base lista para fase 2
model ProductVariant {
  id          String   @id @default(uuid())
  productId   String   @map("product_id")
  tenantId    String   @map("tenant_id")
  name        String                          // "Blanco Mate", "Roble Natural"
  variantType String   @map("variant_type")  // 'color'|'texture'|'material'|'finish'
  sku         String?
  // Datos técnicos de la variante: hex de color, URL de textura, etc.
  metadata    Json?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")

  product  Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  tenant   Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("product_variants")
}

// ============================================================
// LEGACY / COMPAT — kept for backward compat with existing modules
// ============================================================

 // Company is kept as an alias for legacy code; new code uses Tenant
model Company {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users         User[]               @relation("CompanyUsers")
  brands        Brand[]              @relation("CompanyBrands")
  grantedBrandAccess CompanyBrandAccess[] @relation("CompanyBrandAccesses")
  priceLists    CompanyPriceList[]   @relation("CompanyPriceLists")
  discountRules DiscountRule[]       @relation("CompanyDiscountRules")

  @@map("companies")
}

// Legacy User — kept for existing auth module compatibility
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  firstName String
  lastName  String
  tenantId  String   @map("tenant_id")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company  Company    @relation("CompanyUsers", fields: [tenantId], references: [id])
  roles    UserRole[]
  projects Project[]  @relation("ProjectCreator")

  @@map("users")
}

model Role {
  id          String     @id @default(uuid())
  name        String     @unique
  description String?
  users       UserRole[]

  @@map("roles")
}

model UserRole {
  userId String @map("user_id")
  roleId String @map("role_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model CompanyBrandAccess {
  companyId String   @map("company_id")
  brandId   String   @map("brand_id")
  grantedAt DateTime @default(now())
  company   Company  @relation("CompanyBrandAccesses", fields: [companyId], references: [id], onDelete: Cascade)
  brand     Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@id([companyId, brandId])
  @@map("company_brand_access")
}

model Brand {
  id          String   @id @default(uuid())
  name        String
  description String?
  logoUrl     String?
  tenantId    String   @map("tenant_id")
  companyLegacy   Company?             @relation("CompanyBrands", fields: [tenantId], references: [id], map: "brand_legacy_company_fk")
  tenant          Tenant               @relation("LegacyBrands", fields: [tenantId], references: [id], map: "brand_tenant_fk")
  accessRules     CompanyBrandAccess[]

  @@map("brands")
}

model PriceList {
  id        String   @id @default(uuid())
  name      String
  currency  String   @default("USD")
  createdAt DateTime @default(now())

  items     PriceListItem[]
  companies CompanyPriceList[]

  @@map("price_lists")
}

model PriceListItem {
  priceListId String  @map("price_list_id")
  productId   String  @map("product_id_legacy")
  price       Decimal @db.Decimal(10, 2)

  priceList PriceList @relation(fields: [priceListId], references: [id], onDelete: Cascade)

  @@id([priceListId, productId])
  @@map("price_list_items")
}

model CompanyPriceList {
  companyId   String @map("tenant_id")
  priceListId String @map("price_list_id")

  companyLegacy Company   @relation("CompanyPriceLists", fields: [companyId], references: [id], onDelete: Cascade, map: "company_price_list_legacy_company_fk")
  tenant        Tenant    @relation("LegacyCompanyPriceLists", fields: [companyId], references: [id], onDelete: Cascade, map: "company_price_list_tenant_fk")
  priceList     PriceList @relation(fields: [priceListId], references: [id], onDelete: Cascade)

  @@id([companyId, priceListId])
  @@map("company_price_lists")
}

model DiscountRule {
  id            String  @id @default(uuid())
  tenantId      String  @map("tenant_id")
  name          String
  strategyType  String
  configPayload Json
  priority      Int     @default(0)
  active        Boolean @default(true)

  companyLegacy Company @relation("CompanyDiscountRules", fields: [tenantId], references: [id], onDelete: Cascade, map: "discount_rule_legacy_company_fk")
  tenant        Tenant  @relation("LegacyDiscountRules", fields: [tenantId], references: [id], onDelete: Cascade, map: "discount_rule_tenant_fk")

  @@map("discount_rules")
}

model Project {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  name        String
  description String?
  priceType   String   @default("A") @map("price_type")
  creatorId   String   @map("creator_id")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company   Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  creator   User             @relation("ProjectCreator", fields: [creatorId], references: [id])
  versions  ProjectVersion[]

  @@map("projects")
}

model ProjectVersion {
  id         String   @id @default(uuid())
  projectId  String   @map("project_id")
  versionNum Int
  sceneState Json     @map("scene_state_json")
  createdAt  DateTime @default(now())

  project    Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  quotes     Quote[]
  rooms      Room[]
  walls      Wall[]
  openings   Opening[]
  placements Placement[]

  @@unique([projectId, versionNum])
  @@map("project_versions")
}

model Quote {
  id               String   @id @default(uuid())
  tenantId         String   @map("tenant_id")
  projectVersionId String   @map("project_version_id")
  totalAmount      Decimal  @map("total_amount") @db.Decimal(10, 2)
  status           String   @default("DRAFT")
  quoteData        Json
  createdAt        DateTime @default(now())

  projectVersion ProjectVersion @relation(fields: [projectVersionId], references: [id])

  @@map("quotes")
}

model Room {
  id               String  @id @default(uuid())
  projectVersionId String  @map("project_version_id")
  name             String?
  areaSquareMeters Float?  @map("area_square_meters")
  dataJson         Json?

  projectVersion ProjectVersion @relation(fields: [projectVersionId], references: [id], onDelete: Cascade)
  walls          Wall[]
  placements     Placement[]

  @@map("rooms")
}

model Wall {
  id               String  @id @default(uuid())
  projectVersionId String  @map("project_version_id")
  roomId           String? @map("room_id")
  startX           Float   @map("start_x")
  startY           Float   @map("start_y")
  endX             Float   @map("end_x")
  endY             Float   @map("end_y")
  thickness        Float
  height           Float

  projectVersion ProjectVersion @relation(fields: [projectVersionId], references: [id], onDelete: Cascade)
  room           Room?          @relation(fields: [roomId], references: [id], onDelete: SetNull)
  openings       Opening[]

  @@map("walls")
}

model Opening {
  id               String @id @default(uuid())
  projectVersionId String @map("project_version_id")
  wallId           String @map("wall_id")
  type             String
  positionX        Float  @map("position_x")
  width            Float
  height           Float

  projectVersion ProjectVersion @relation(fields: [projectVersionId], references: [id], onDelete: Cascade)
  wall           Wall           @relation(fields: [wallId], references: [id], onDelete: Cascade)

  @@map("openings")
}

model Placement {
  id               String  @id @default(uuid())
  projectVersionId String  @map("project_version_id")
  roomId           String? @map("room_id")
  productId        String  @map("product_id")
  posX             Float   @map("pos_x")
  posY             Float   @map("pos_y")
  posZ             Float   @map("pos_z")
  rotX             Float   @map("rot_x")
  rotY             Float   @map("rot_y")
  rotZ             Float   @map("rot_z")

  projectVersion ProjectVersion @relation(fields: [projectVersionId], references: [id], onDelete: Cascade)
  room           Room?          @relation(fields: [roomId], references: [id], onDelete: SetNull)

  @@map("placements")
}
